# ── Supabase (REQUIRED) ───────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=your_project_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ── Stripe (REQUIRED for payments) ───────────────────────
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
STRIPE_MARKETPLACE_WEBHOOK_SECRET=whsec_your_marketplace_webhook_secret_here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
STRIPE_MONTHLY_PRICE_ID=price_your_monthly_price_id_here
STRIPE_YEARLY_PRICE_ID=price_your_yearly_price_id_here
STRIPE_COURSE_PRICE_ID=price_your_course_price_id_here
STRIPE_COURSE_PRO_PRICE_ID=price_your_course_pro_price_id_here

# ── Email / Resend (REQUIRED for all emails) ─────────────
RESEND_API_KEY=re_your_resend_api_key_here
# Verified sender domains in Resend:
#   fees@invest.com.au      (default sender)
#   partners@invest.com.au  (broker communications)
#   hello@invest.com.au     (advisor/consultation)
#   leads@invest.com.au     (lead notifications)
#   weekly@invest.com.au    (newsletter)
#   alerts@invest.com.au    (alert notifications)
#   billing@invest.com.au   (billing alerts)

# ── Cron / Internal (REQUIRED for automations) ───────────
CRON_SECRET=your_cron_secret_here
INTERNAL_API_KEY=your_internal_api_key_here
# Used by /api/revalidate to purge ISR cache on demand
REVALIDATE_SECRET=your_revalidate_secret_here
# Used by /api/partner/leads for partner API access
PARTNER_API_KEY=your_partner_api_key_here

# ── Admin (REQUIRED) ─────────────────────────────────────
# Comma-separated list of emails allowed to access /admin
ADMIN_EMAILS=you@invest.com.au
ADMIN_EMAIL=admin@invest.com.au

# ── AI (optional — AI assistant + content generation) ─────
# Option A: Anthropic (paid per token)
ANTHROPIC_API_KEY=sk-ant-your_anthropic_key_here
# Option B: Google Gemini (free tier available)
# GOOGLE_AI_API_KEY=your_google_ai_key_here

# ── Vercel (optional — for AI assistant deploy management) ─
VERCEL_API_TOKEN=your_vercel_api_token_here

# ── Error Monitoring (recommended) ───────────────────────
NEXT_PUBLIC_SENTRY_DSN=https://your_key@o12345.ingest.sentry.io/12345

# ── Security ─────────────────────────────────────────────
# Salt used for hashing IPs in click tracking (optional, has default)
IP_HASH_SALT=your_random_salt_here

# ── URLs ─────────────────────────────────────────────────
# Used in emails, sitemap, OG images — set to your production domain
NEXT_PUBLIC_SITE_URL=https://invest.com.au
NEXT_PUBLIC_BASE_URL=https://invest.com.au

# ── Analytics ────────────────────────────────────────────
NEXT_PUBLIC_GA_ID=G-RC473QKMTN
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-RC473QKMTN
