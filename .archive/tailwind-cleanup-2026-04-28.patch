+  };
+
+  useEffect(() => {
+    loadFirmData();
+  }, [loadFirmData]);
+
+  return (
+    <div>
+      <div className="flex items-center justify-between mb-4">
+        <div>
+          <h2 className="text-lg font-bold text-slate-900">{firmDetails?.name || "Team"}</h2>
