{
  "name": "invest-com-au",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:changed": "vitest run --changed",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:install": "playwright install --with-deps chromium webkit",
    "bots": "playwright test --config bots/playwright.config.ts",
    "bots:install": "playwright install --with-deps chromium",
    "bots:seed-users": "npx tsx scripts/seed-bot-users.ts",
    "bots:sandbox": "BOTS_TARGET_CLASS=sandbox playwright test --config bots/playwright.config.ts",
    "bots:mirror": "BOTS_BASE_URL=https://lambent-sawine-17c3dd.netlify.app BOTS_IGNORE_HTTPS_ERRORS=1 BOTS_SKIP_WEBSERVER=1 playwright test --config bots/playwright.config.ts",
    "bots:advisors": "BOTS_BASE_URL=https://lambent-sawine-17c3dd.netlify.app BOTS_IGNORE_HTTPS_ERRORS=1 BOTS_SKIP_WEBSERVER=1 playwright test --config bots/playwright.config.ts -g \"advisor\"",
    "bots:authed": "BOTS_TARGET_CLASS=sandbox BOTS_SKIP_WEBSERVER=1 BOTS_BASE_URL=http://localhost:3000 playwright test --config bots/playwright.config.ts -g \"authed bot\"",
    "bots:authed-and-lifecycle": "BOTS_TARGET_CLASS=sandbox BOTS_SKIP_WEBSERVER=1 BOTS_BASE_URL=http://localhost:3000 playwright test --config bots/playwright.config.ts -g \"authed bot|lifecycle\"",
    "bots:lifecycle": "BOTS_TARGET_CLASS=sandbox playwright test --config bots/playwright.config.ts -g \"lifecycle\"",
    "bots:lifecycle-mirror": "BOTS_BASE_URL=https://lambent-sawine-17c3dd.netlify.app BOTS_IGNORE_HTTPS_ERRORS=1 BOTS_SKIP_WEBSERVER=1 playwright test --config bots/playwright.config.ts -g \"lifecycle\"",
    "bots:startup": "BOTS_BASE_URL=https://lambent-sawine-17c3dd.netlify.app BOTS_IGNORE_HTTPS_ERRORS=1 BOTS_SKIP_WEBSERVER=1 playwright test --config bots/playwright.config.ts -g \"startup-ecosystem\"",
    "bots:advisor-portal": "BOTS_BASE_URL=https://lambent-sawine-17c3dd.netlify.app BOTS_IGNORE_HTTPS_ERRORS=1 BOTS_SKIP_WEBSERVER=1 playwright test --config bots/playwright.config.ts -g \"advisor-portal\"",
    "bots:file-issues": "npx tsx scripts/bots-file-issues.ts",
    "bots:diff": "npx tsx scripts/bots-diff-baseline.ts",
    "bots:probe-api": "npx tsx scripts/bots-probe-api.ts",
    "bots:nightly": "node scripts/bots-nightly.mjs",
    "bots:funnel": "node scripts/bots-funnel-monitor.mjs",
    "bots:seo": "node scripts/bots-seo-audit.mjs",
    "bots:idor": "node scripts/bots-idor-probe.mjs",
    "bots:perf": "node scripts/bots-perf-budget.mjs",
    "bots:a11y": "node scripts/bots-a11y.mjs",
    "bots:data": "node scripts/bots-data-integrity.mjs",
    "bots:visual": "node scripts/bots-visual.mjs",
    "bots:conversion": "node scripts/bots-conversion.mjs",
    "bots:redteam": "node scripts/bots-llm-redteam.mjs",
    "screenshots": "playwright test --config e2e/visual/playwright.config.ts e2e/visual/screenshots.spec.ts",
    "screenshots:seed": "node scripts/screenshots-seed.mjs",
    "screenshots:auto-seed": "node scripts/screenshots-auto-seed.mjs",
    "screenshots:auto-login": "playwright test --config e2e/visual/playwright.config.ts e2e/visual/auto-login.spec.ts",
    "analyze": "ANALYZE=true next build",
    "audit:rate-limits": "node scripts/rate-limit-coverage.mjs",
    "audit:dated-strings": "node scripts/check-dated-strings.mjs",
    "audit:rls-isolation": "node scripts/check-rls-isolation.mjs",
    "audit:stripe-idempotency": "node scripts/check-stripe-idempotency.mjs",
    "audit:stale-dated-stats": "node scripts/check-stale-dated-stats.mjs",
    "audit:dated-stats": "node scripts/check-stale-dated-stats.mjs",
    "audit:rls-migrations": "node scripts/check-rls-migrations.mjs",
    "audit:drift-types": "node scripts/check-database-types-drift.mjs",
    "audit:schema-refs": "node scripts/check-schema-references.mjs",
    "audit:financial-invariants": "node scripts/check-financial-invariants.mjs",
    "audit:unapplied-migrations": "node scripts/audit/unapplied-migrations.mjs",
    "audit:console-calls": "node scripts/check-console-calls.mjs",
    "audit:duplicate-functions": "node scripts/check-duplicate-functions.mjs",
    "audit:stale-branches": "node scripts/check-stale-branches.mjs",
    "audit:jsonld-coverage": "node scripts/check-jsonld-coverage.mjs",
    "db:types": "npx supabase gen types typescript --project-id ${SUPABASE_PROJECT_ID} > lib/database.types.ts",
    "db:types:check": "npx supabase gen types typescript --project-id ${SUPABASE_PROJECT_ID} > /tmp/database.types.generated.ts && diff -u lib/database.types.ts /tmp/database.types.generated.ts",
    "prepare": "husky || true"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.96.0",
    "@sentry/nextjs": "^10.53.1",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.105.4",
    "@tailwindcss/typography": "^0.5.16",
    "@vercel/speed-insights": "^2.0.0",
    "next": "16.2.6",
    "posthog-js": "^1.373.5",
    "posthog-node": "^5.34.2",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "stripe": "^17.7.0",
    "yahoo-finance2": "^3.14.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@next/bundle-analyzer": "^16.2.6",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/node": "^25",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.5",
    "postcss": "^8.5.14",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "vitest": "^3.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix --max-warnings 0"
    ]
  },
  "overrides": {
    "picomatch": "^2.3.2"
  }
}
