{
  "ci": {
    "collect": {
      "startServerCommand": "npm run start",
      "startServerReadyPattern": "Ready",
      "url": [
        "http://localhost:3000/",
        "http://localhost:3000/glossary",
        "http://localhost:3000/how-we-earn"
      ],
      "numberOfRuns": 3,
      "settings": {
        "preset": "desktop",
        "chromeFlags": "--no-sandbox --headless=new"
      }
    },
    "assert": {
      "aggregationMethod": "median-run",
      "assertions": {
        "largest-contentful-paint": ["error", { "maxNumericValue": 6000 }],
        "cumulative-layout-shift": ["error", { "maxNumericValue": 0.2 }],
        "total-blocking-time": ["error", { "maxNumericValue": 1500 }]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
